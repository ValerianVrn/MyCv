@using MyCv.UI.Wasm.Services
@using MyCv.UI.Wasm.Services
@using MyCv.UI.Wasm.Shared
@inject IStringLocalizer<MyCv.UI.Wasm.Resources.Components.Pages.Home> Localizer
@inject IConfiguration Configuration

<MudPaper Class="section-tinted py-8" Square="true" Elevation="0">
    <MudContainer Class="px-4 px-lg-20">
        <MudText Typo="Typo.h2" Align="Align.Left" Class="@Style.LargeBottomMargin">
            @Localizer["HomeHeader"]
            <MudText Color="Color.Primary" Typo="Typo.h2" Inline="true">Valérian</MudText>.
        </MudText>
        <MudGrid Justify="Justify.Center">
            @* Terminal *@
            <MudItem xs="12" sm="9">
                <Terminal />
            </MudItem>
            @* Portrait *@
            <MudItem xs="8" sm="3" Class="d-flex align-center">
                <MudImage Fluid="true" Src="images/portrait.jpg" Alt="Portrait" Class="rounded-lg" />
            </MudItem>
            @* Introduction *@
            <MudItem xs="10" md="10">
                <MudText Typo="Typo.body1" Align="Align.Center" GutterBottom="true">
                    @Localizer["HomeIntroduction"]
                </MudText>
                <MudText Typo="Typo.body1" Align="Align.Center" GutterBottom="true">
                    @Localizer["HomeSourceCode"] <MudLink Href="https://github.com/ValerianVrn/MyCv.git">GitHub</MudLink>.
                </MudText>
            </MudItem>
        </MudGrid>
    </MudContainer>
</MudPaper>
