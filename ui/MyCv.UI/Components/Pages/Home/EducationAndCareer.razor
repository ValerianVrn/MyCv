@using MyCv.UI.Services
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Home> Localizer
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Career> CareerLocalizer;
@inject IThemeService ThemeService

<MudContainer Class="py-8">
    <MudContainer Class="@Style.LargeBottomMargin">
        <MudText Typo="Typo.h4" Align="Align.Center">@Localizer["MoreAboutMe"]</MudText>
        <MudText Typo="Typo.body1" Align="Align.Center">@Localizer["MoreAboutMeCaption"]</MudText>
    </MudContainer>
    <MudGrid>
        <MudItem xs="12">
            <MudTimeline Modifiers>
                @foreach (var year in _degrees.Keys)
                {
                    <MudTimelineItem Color="Color.Primary" Elevation="25" TimelineAlign="TimelineAlign.End">
                        <ItemOpposite>
                            <MudText Typo="Typo.h6">@year</MudText>
                        </ItemOpposite>
                        <ItemContent>
                            @foreach (var degree in _degrees[year])
                            {
                                <MudStack Row Spacing="6" AlignItems="AlignItems.Center">
                                    <MudImage Src="@degree.Image" Alt="@degree.SubTitle" Width="48" Height="48" ObjectFit="ObjectFit.Contain" Class="rounded-lg border bg-white" />
                                    <MudStack Spacing="0" Class="pa-0">
                                        <MudText Color="Color.Primary" GutterBottom="false">@degree.Name</MudText>
                                        <MudText Typo="Typo.subtitle1" Inline>@degree.SubTitle</MudText>
                                    </MudStack>
                                </MudStack>
                            }
                        </ItemContent>
                    </MudTimelineItem>
                }
            </MudTimeline>
        </MudItem>
        <MudItem xs="4" Class="d-flex justify-center">
            <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body1" GutterBottom>@CareerLocalizer["Introduction"]</MudText>
                <MudButton Href="@Urls.EducationAndCareer" Variant="Variant.Filled" Color="Color.Primary" FullWidth="false">@Localizer["MoreAboutMe"]</MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>


@code {

    private record Degree(string Image, string Name, string SubTitle);
    private Dictionary<int, List<Degree>> _degrees = new();

    protected override void OnInitialized()
    {
        _degrees = new() {
            { 2014, [
                new("images/tlcom_physique_strasbourg_logo.jpg", CareerLocalizer["EducationEngineeringDegree"], "Télécom Physique Strasbourg - " + CareerLocalizer["EducationPartnerOf", "IMT"]),
                new("images/universite_de_strasbourg_logo.jpg", CareerLocalizer["EducationMaster"], "Université de Strasbourg")] },
            { 2015, [ new("images/em_strasbourg_logo.jpg", CareerLocalizer["EducationMaster"],  "EM Strasbourg Business School") ] },
            { 2016, [ new("images/ei.jpeg", CareerLocalizer["SectionExperienceEiJobTitle"],  "Crédit Mutuel") ] },
            { 2018, [ new("images/cea.png", CareerLocalizer["SectionExperienceCeaJobTitle"],  "CEA") ] },
            { 2019, [ new("images/Fives_Group.png", CareerLocalizer["SectionExperienceSylepsJobTitle"],  "Fives Syleps") ] },
            { 2022, [ new("images/Fives_Group.png", CareerLocalizer["SectionExperienceXcellaJobTitle"],  "Fives Xcella") ] },
        };
    }
}
