@using MyCv.UI.Components.Shared.Content
@inject IStringLocalizer<MyCv.UI.Resources.Shared> SharedLocalizer;
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Career> Localizer;

<Page>
