@* ═══════════════════════════════════════════════
    ExperienceCardContent.razor
    Shared inner content, used by both wrappers
═══════════════════════════════════════════════ *@
@inject IStringLocalizer<MyCv.UI.Resources.Shared> SharedLocalizer

<MudStack Spacing="3">
    @if (!IsCompact)
    {
        @* Header *@
        <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
            <MudAvatar Style="background:white; border:1px solid var(--mud-palette-divider);" Size="@(IsInternship? Size.Small: Size.Large)">
                <MudImage Src="@CompanyLogo" Alt="company-logo"
                          Width="@(IsInternship ? 24 : 40)" Height="@(IsInternship ? 24 : 40)"
                          ObjectFit="ObjectFit.Contain" />
            </MudAvatar>
            <MudStack Spacing="0">
                <MudText Typo="@(IsInternship? Typo.subtitle1: Typo.h6)"><strong>@JobTitle</strong></MudText>
                <MudText Typo="@(IsInternship? Typo.body2: Typo.subtitle1)" Color="Color.Primary">@Company</MudText>
            </MudStack>
        </MudStack>

        @* Date + location *@
        <MudStack Spacing="1">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Color="@(IsInternship? Color.Default: Color.Info)" />
                <MudText Typo="Typo.body2">@StartDate.ToString("MMM yyyy") – @EndDate.ToString("MMM yyyy") · @_duration</MudText>
            </MudStack>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Color="@(IsInternship? Color.Default: Color.Info)" />
                <MudText Typo="Typo.body2">@Place</MudText>
            </MudStack>
        </MudStack>

        <MudDivider />
    }
    @* Projects *@
    @foreach (var project in Projects)
    {
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2"><strong>@project.Title</strong></MudText>
            @foreach (var task in project.Tasks ?? [])
            {
                <MudStack Row AlignItems="AlignItems.Start" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                             Color="@(IsInternship ? Color.Default : Color.Info)"
                             Style="margin-top:2px" />
                    <MudText Typo="Typo.body2">@task</MudText>
                </MudStack>
            }
        </MudStack>
    }

    @* Skills *@
    @if (Skills?.Any() ?? false)
    {
        <MudDivider />
        <MudStack Row Wrap="Wrap.Wrap" Spacing="1">
            @foreach (var skill in Skills)
            {
                <MudChip T="string"
                         Color="@(IsInternship ? Color.Default : Color.Info)"
                         Variant="Variant.Outlined"
                         Size="Size.Small"
                         Class="@(IsInternship ? "" : "core-chip")">
                    @skill
                </MudChip>
            }
        </MudStack>
    }
</MudStack>

@code {
    public record Project(string Title, List<string>? Tasks);

    [Parameter] public required string CompanyLogo { get; set; }
    [Parameter] public required string JobTitle { get; set; }
    [Parameter] public required string Company { get; set; }
    [Parameter] public required DateTime StartDate { get; set; }
    [Parameter] public required DateTime EndDate { get; set; }
    [Parameter] public required string Place { get; set; }
    [Parameter] public required List<Project> Projects { get; set; }
    [Parameter] public List<string>? Skills { get; set; }
    [Parameter] public bool IsInternship { get; set; } = false;
    [Parameter] public bool IsCompact { get; set; } = false;

    private string _duration = "";

    protected override void OnParametersSet() =>
        _duration = ComputeDurationString(StartDate, EndDate);

    private string ComputeDurationString(DateTime start, DateTime end)
    {
        if (end < start) (start, end) = (end, start);
        var totalMonths = (end.Year - start.Year) * 12 + (end.Month - start.Month) + 1;
        if (end.Day < start.Day) totalMonths--;
        if (totalMonths <= 0) return "";
        var years = totalMonths / 12;
        var months = totalMonths % 12;
        string YearPart() => years > 0 ? $"{years} {(years > 1 ? SharedLocalizer["Years"] : SharedLocalizer["Year"])}" : "";
        string MonthPart() => months > 0 ? $"{months} {(months > 1 ? SharedLocalizer["Months"] : SharedLocalizer["Month"])}" : "";
        return years > 0 ? (months > 0 ? $"{YearPart()} {MonthPart()}" : YearPart()) : MonthPart();
    }
}
