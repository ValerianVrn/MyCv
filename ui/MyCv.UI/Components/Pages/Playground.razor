@page "/playground"
@using MyCv.UI.Components.Layout
@using MyCv.UI.Components.Pages.Architecture
@using MyCv.UI.Components.Shared
@using MyCv.UI.Components.Shared.Content
@using MyCv.UI.Dtos
@using MyCv.UI.Services
@* @layout MainLayout *@
@inject IWebHostEnvironment Env

@if (Env.IsDevelopment())
{
    <Architecture></Architecture>
}
else
{
    @* Optional: redirect or show nothing *@
    @* <RedirectToLogin /> @* or NavigationManager.NavigateTo("/") *@
}


@code {
    private List<Menu.Section> _sectionMenuItems { get; set; } = [];

    private List<string> _sectionNames { get; set; } = [
        "CQRS",
        "Event sourcing",
    ];

    /// <inheritdoc/>
    protected override void OnInitialized()
    {
        // if (firstRender)
        {
            _sectionMenuItems = _sectionNames.Select(s => new Menu.Section(s, $"#{s.Replace(" ", "-").ToLower()}")).ToList();

        }
    }
}
