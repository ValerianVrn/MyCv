@inject IStringLocalizer<Resource> Localizer

<MudPaper Class="pa-4" Elevation="0" Square="true">
    <MudStack Justify="Justify.Center" Spacing="1">
        <MudStack Justify="Justify.Center" Spacing="0">
            <MudText Typo="Typo.body1" Align="Align.Center">
                © @DateTime.Now.Year Valérian Verona. @Localizer["Title"]
            </MudText>
            <MudText Typo="Typo.caption" Align="Align.Center" Class="mud-text-secondary">
                @Localizer["FooterAbout"]
            </MudText>
        </MudStack>
        <MudStack Row="true" Justify="Justify.Center">
            <SocialItems />
        </MudStack>
    </MudStack>
</MudPaper>

