@inject IStringLocalizer<Resource> Localizer

<!-- Desktop -->
@* <MudHidden Breakpoint="Breakpoint.LgAndUp" Invert="true"> *@
    <MudDrawer Fixed="true" ClipMode="DrawerClipMode.Always" Anchor="Anchor.Left" Open="true" Variant="DrawerVariant.Persistent" Elevation="0" Class="py-6">
        <MudNavMenu Bordered="true" id="content-menu">
            <MudText Typo="Typo.h6" Class="px-4">@Localizer["Content"]</MudText>
            <MudDivider Class="my-2" />
            @if (Sections?.Count() > 0)
            {
                @foreach (var sectionItem in Sections)
                {
                    <MudNavLink Href="@sectionItem.Href" Match="NavLinkMatch.All">
                        @sectionItem.Name
                    </MudNavLink>
                }
            }
        </MudNavMenu>
    </MudDrawer>
@* </MudHidden> *@

@code {
    public record Section(string Name, string Href);

    [Parameter]
    public List<Section>? Sections { get; set; }

    // [Parameter]
    // public required string CurrentSectionHref { get; set; }
}
