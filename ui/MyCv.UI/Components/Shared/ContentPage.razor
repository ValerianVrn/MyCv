@* Main content of the page *@
<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudGrid Spacing="10" Justify="Justify.Center">
        <CascadingValue Value="ContentMenu">
            @Header
            @Sections
        </CascadingValue>
    </MudGrid>
</MudContainer>

@code {
    [CascadingParameter]
    public required ContentMenu ContentMenu { get; set; }

    [Parameter]
    public required RenderFragment Header { get; set; }

    [Parameter]
    public required RenderFragment Sections { get; set; }

    protected override void OnParametersSet()
    {
        ContentMenu.ClearSections();
    }
}
