@page "/coding"
@using MyCv.UI.Components.Shared
@using MyCv.UI.Components.Shared.Content
@inject IStringLocalizer<MyCv.UI.Resources.Shared> SharedLocalizer;
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Coding> Localizer;

<Page>
    <Header HeaderId="introduction" HeaderName="@SharedLocalizer["DotNetExpertise"]" Chips="@(["Clean code", "Best practices", "Git flow", "Testing"])">
        <MudText Typo="Typo.body1">@Localizer["HeaderIntroduction"]</MudText>
        <MudAlert Severity="Severity.Success">@((MarkupString)(string)Localizer["HeaderTechLead"])</MudAlert>
    </Header>
    <BestPractices></BestPractices>
    <Git></Git>
    <DesignPatterns></DesignPatterns>
    <UnitTests></UnitTests>
    <FunctionalTests></FunctionalTests>
</Page>
