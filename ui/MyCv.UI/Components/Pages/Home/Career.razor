@using MyCv.UI.Services
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Home> Localizer
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Career> CareerLocalizer;
@inject IStringLocalizer<MyCv.UI.Resources.Shared> SharedLocalizer;
@inject IThemeService ThemeService
@inject IConfiguration Configuration


<MudContainer Class="py-8" id="career">
    <MudContainer Class="@Style.LargeBottomMargin">
        <MudText Typo="Typo.h4" Align="Align.Center">@SharedLocalizer["Career"]</MudText>
        @if (Configuration.GetValue<bool>("SinglePage"))
        {
            <MudText Typo="Typo.body1" Align="Align.Center">@CareerLocalizer["Introduction"]</MudText>
        }
    </MudContainer>
    <MudContainer Class="@Style.LargeBottomMargin">

        <MudTimeline TimelinePosition="TimelinePosition.Start" Modifiers>

            @* Xcella *@
            <ExperienceItem CompanyLogo="images/Fives_Group.png"
                            JobTitle="@CareerLocalizer["SectionExperienceXcellaJobTitle"]"
                            Company="Fives Xcella"
                            StartDate=@(new DateTime(2022, 03, 01))
                            EndDate=@(new DateTime(2025, 12, 01))
                            Place="@CareerLocalizer["SectionExperienceXcellaPlace"]"
                            Projects=@([new(CareerLocalizer["SectionExperienceXcellaProjectTitle"], [
                                                        CareerLocalizer["SectionExperienceXcellaTask1"],
                                                        CareerLocalizer["SectionExperienceXcellaTask2"],
                                                        CareerLocalizer["SectionExperienceXcellaTask3"],
                                                        CareerLocalizer["SectionExperienceXcellaTask4"]])])
                            Skills=@(["C#/.NET", "Software architecture", "Azure DevOps", "Docker" ]) />
            @* Syleps *@
            <ExperienceItem CompanyLogo="images/Fives_Group.png"
                            JobTitle="@CareerLocalizer["SectionExperienceSylepsJobTitle"]"
                            Company="Fives Syleps"
                            StartDate=@(new DateTime(2019, 12, 01))
                            EndDate=@(new DateTime(2022, 02, 01))
                            Place="@CareerLocalizer["SectionExperienceSylepsPlace"]"
                            Projects=@([
                                                        new(CareerLocalizer["SectionExperienceSylepsProject1Title"], null),
                                                        new(CareerLocalizer["SectionExperienceSylepsProject2Title"], null),
                                                        new(CareerLocalizer["SectionExperienceSylepsProject3Title"], null)])
                            Skills=@(["C#/.NET", "Software architecture", "Azure DevOps", "Docker", "PL/SQL", "Git", "API REST"]) />
            @* CEA *@
            <ExperienceItem CompanyLogo="images/cea.png"
                            JobTitle="@CareerLocalizer["SectionExperienceCeaJobTitle"]"
                            Company="CEA - Commissariat à l'énergie atomique et aux énergies alternatives"
                            StartDate=@(new DateTime(2018, 11, 01))
                            EndDate=@(new DateTime(2019, 03, 01))
                            Place="@CareerLocalizer["SectionExperienceCeaPlace"]"
                            Projects=@([ new(CareerLocalizer["SectionExperienceCeaProjectTitle"], null)])
                            Skills=@([ "C++", "Qt", "Python", "Matlab" ]) />
            @* Crédit Mutuel *@
            <ExperienceItem CompanyLogo="images/ei.jpeg"
                            JobTitle="@CareerLocalizer["SectionExperienceEiJobTitle"]"
                            Company="Euro Information (Crédit Mutuel)"
                            StartDate=@(new DateTime(2016, 02, 01))
                            EndDate=@(new DateTime(2017, 12, 01))
                            Place="@CareerLocalizer["SectionExperienceEiPlace"]"
                            Projects=@([ new(CareerLocalizer["SectionExperienceEiProjectTitle"], null)])
                            Skills=@([ "C#/.NET", "SQL Server", "SOAP" ]) />
            @* GE Healthcare *@
            <ExperienceItem CompanyLogo="images/ge.png"
                            JobTitle="@CareerLocalizer["SectionExperienceGeJobTitle"]"
                            Company="GE Healthcare"
                            StartDate=@(new DateTime(2015, 03, 01))
                            EndDate=@(new DateTime(2015, 08, 01))
                            Place="@CareerLocalizer["SectionExperienceGePlace"]"
                            Projects=@([new(CareerLocalizer["SectionExperienceGeProjectTitle"], null) ]) />
            @* Inria *@
            <ExperienceItem CompanyLogo="images/inria.png"
                            JobTitle="@CareerLocalizer["SectionExperienceInriaJobTitle"]"
                            Company="Inria"
                            StartDate=@(new DateTime(2014, 03, 01))
                            EndDate=@(new DateTime(2014, 08, 01))
                            Place="@CareerLocalizer["SectionExperienceInriaPlace"]"
                            Projects=@([new(CareerLocalizer["SectionExperienceInriaProjectTitle"], null)])
                            Skills=@([ "C++", "Qt", "Python" ]) />
            @* Siemens *@
            <ExperienceItem CompanyLogo="images/siemens.png"
                            JobTitle="@CareerLocalizer["SectionExperienceSiemensJobTitle"]"
                            Company="Siemens"
                            StartDate=@(new DateTime(2013, 06, 01))
                            EndDate=@(new DateTime(2013, 08, 01))
                            Place="@CareerLocalizer["SectionExperienceSiemensPlace"]"
                            Projects=@([new(CareerLocalizer["SectionExperienceSiemensProjectTitle"], null)])
                            Skills=@([ "C++", "Matlab/Simulink" ]) />
        </MudTimeline>
    </MudContainer>
</MudContainer>


@code {

}
