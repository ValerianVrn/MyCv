@inject IStringLocalizer<Resource> Localizer

<!-- Desktop -->
<MudHidden Breakpoint="Breakpoint.LgAndUp" Invert="true">
    <MudDrawer Fixed="true" ClipMode="DrawerClipMode.Always" Anchor="Anchor.Left" Open="true" Variant="DrawerVariant.Persistent" Elevation="0" Class="py-6">
        <MudNavMenu Bordered="true">
            <MudText Typo="Typo.h6" Class="px-4">@Localizer["Content"]</MudText>
            <MudDivider Class="my-2" />
            @if (Sections?.Count() > 0)
            {
                @foreach (var sectionItem in Sections)
                {
                    <MudNavLink Href="@sectionItem.Href"
                                Match="NavLinkMatch.All"
                                Icon="@(sectionItem.Href == CurrentSectionHref ? Icons.Material.Filled.Circle : Icons.Material.Outlined.Circle)"
                                IconColor="@(sectionItem.Href == CurrentSectionHref ? Color.Primary : Color.Default)"
                                Class="@(sectionItem.Href == CurrentSectionHref ? "mud-nav-link-active" : "")">
                        @sectionItem.Name
                    </MudNavLink>
                }
            }
        </MudNavMenu>
    </MudDrawer>
</MudHidden>

@code {
    public record Section(string Id, string Href, string Name);

    [Parameter]
    public List<Section>? Sections { get; set; }

    [Parameter]
    public required string CurrentSectionHref { get; set; }
}
