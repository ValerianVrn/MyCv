<MudContainer Gutters="false">
    <MudText Typo="Typo.h6" Align="Align.Left">@SubSectionName</MudText>
    @ChildContent
</MudContainer>

@code {
    [Parameter]
    public required string SubSectionName { get; set; }

    [Parameter]
    public required RenderFragment ChildContent { get; set; }
}
