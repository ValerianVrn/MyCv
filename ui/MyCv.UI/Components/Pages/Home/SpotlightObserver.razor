@inject IJSRuntime JS

@code {
    [Parameter]
    public string[] Selectors { get; set; } = [];

    [Parameter]
    public string RootMargin { get; set; } = "-35% 0px -35% 0px";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await JS.InvokeVoidAsync("spotlight.init", Selectors, RootMargin);
        await JS.InvokeVoidAsync("spotlight.highlightAll", "#skills", ".core-chip");
    }
}
