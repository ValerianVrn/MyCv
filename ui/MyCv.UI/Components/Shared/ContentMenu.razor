@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager

<!-- Desktop -->
<MudHidden Breakpoint="Breakpoint.LgAndUp" Invert="true">
    <MudDrawer Fixed="true" ClipMode="DrawerClipMode.Docked" Anchor="Anchor.Left" Open="@_opened" Variant="DrawerVariant.Persistent" Elevation="0" Class="py-6">
        <MudNavMenu Bordered="true" id="content-menu">
            <MudText Typo="Typo.h6" Class="px-4">@Localizer["Content"]</MudText>
            <MudDivider Class="my-2" />
            @if (_sections?.Count() > 0)
            {
                @foreach (var sectionItem in _sections)
                {
                    <MudNavLink Href="@GetHref(sectionItem.Id)" Match="NavLinkMatch.Prefix">
                        @sectionItem.Name
                    </MudNavLink>
                }
            }
        </MudNavMenu>
    </MudDrawer>
</MudHidden>

@code {
    public record Section(string Id, string Name);

    private List<Section> _sections = new();
    private bool _opened;

    /// <summary>
    /// Register sections for creating the menu.
    /// </summary>
    /// <param name="sectionId"></param>
    /// <param name="sectionName"></param>
    public void RegisterSection(string sectionId, string sectionName)
    {
        if (!_sections.Any(s => s.Id == sectionId))
        {
            _sections.Add(new(sectionId, sectionName));
            _opened = true;
        }

        StateHasChanged();
    }

    /// <summary>
    /// Clear the existing sections.
    /// </summary>
    public void ClearSections()
    {
        _sections = [];
        StateHasChanged();
    }

    /// <summary>
    /// Close the menu.
    /// </summary>
    public void Close()
    {
        _opened = false;
        StateHasChanged();
    }

    private string GetHref(string id)
    {
        return $"{NavigationManager.ToBaseRelativePath(NavigationManager.Uri)}#{id.Replace(" ", "-").ToLower()}";
    }
}
