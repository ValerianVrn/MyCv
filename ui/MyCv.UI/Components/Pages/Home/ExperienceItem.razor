@inject IStringLocalizer<MyCv.UI.Resources.Shared> SharedLocalizer;

@if (IsInternship)
{
    @* ── COMPACT card for internships ── *@
    <MudTimelineItem Size="Size.Small" Color="Color.Default">
        <MudCard Class="timeline-card-mini rounded-lg mb-2" Elevation="2">
            <MudCardContent Class="py-2 px-4">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudAvatar Style="background:white; border:1px solid var(--mud-palette-divider);" Size="Size.Medium">
                        <MudImage Src="@CompanyLogo" Alt="company-logo" Width="32" Height="32" ObjectFit="ObjectFit.Contain" />
                    </MudAvatar>
                    <MudStack Spacing="0" Style="flex:1">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.subtitle2"><strong>@JobTitle</strong></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Primary">@Company</MudText>
                        </MudStack>
                        <MudText Typo="Typo.caption">
                            @StartDate.ToString("MMM yyyy") – @EndDate.ToString("MMM yyyy") · @_duration · @Place
                        </MudText>
                    </MudStack>
                    <MudIconButton Icon="@(_expanded? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small"
                                   OnClick="OnExpandCollapseClick" />
                </MudStack>
            </MudCardContent>
            <MudCollapse Expanded="_expanded">
                <MudCardContent Class="px-4 pt-0 pb-3">
                    <MudDivider Class="mb-3" />
                    @foreach (var project in Projects)
                    {
                        <MudStack Spacing="1" Class="mb-2">
                            <MudText Typo="Typo.subtitle2"><strong>@project.Title</strong></MudText>
                            @foreach (var task in project.Tasks ?? [])
                            {
                                <MudStack Row AlignItems="AlignItems.Start" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" Style="margin-top:2px" />
                                    <MudText Typo="Typo.body2">@task</MudText>
                                </MudStack>
                            }
                        </MudStack>
                    }
                    @if (Skills?.Any() ?? false)
                    {
                        <MudStack Row Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                            @foreach (var skill in Skills)
                            {
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">@skill</MudChip>
                            }
                        </MudStack>
                    }
                </MudCardContent>
            </MudCollapse>
        </MudCard>
    </MudTimelineItem>
}
else
{
    @* ── FULL card for real experiences ── *@
    <MudTimelineItem Size="Size.Medium" Color="Color.Info">
        <MudCard Class="timeline-card rounded-lg mb-4" Elevation="6">
            <div class="timeline-accent"></div>
            <MudCardContent Class="px-4 px-lg-8 py-4">
                <MudStack>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                        <MudAvatar Style="background:white; border:1px solid var(--mud-palette-divider);" Size="Size.Large">
                            <MudImage Src="@CompanyLogo" Alt="company-logo" Width="40" Height="40" ObjectFit="ObjectFit.Contain" />
                        </MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6"><strong>@JobTitle</strong></MudText>
                            <MudText Typo="Typo.subtitle1" Color="Color.Primary">@Company</MudText>
                        </MudStack>
                    </MudStack>
                    <MudStack Spacing="1">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Color="Color.Info" />
                            <MudText Typo="Typo.body2">@StartDate.ToString("MMM yyyy") – @EndDate.ToString("MMM yyyy") · @_duration</MudText>
                        </MudStack>
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Color="Color.Info" />
                            <MudText Typo="Typo.body2">@Place</MudText>
                        </MudStack>
                    </MudStack>
                    <MudDivider />
                    @foreach (var project in Projects)
                    {
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2"><strong>@project.Title</strong></MudText>
                            @foreach (var task in project.Tasks ?? [])
                            {
                                <MudStack Row AlignItems="AlignItems.Start" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Info" Style="margin-top:2px" />
                                    <MudText Typo="Typo.body2">@task</MudText>
                                </MudStack>
                            }
                        </MudStack>
                    }
                    @if (Skills?.Any() ?? false)
                    {
                        <MudDivider />
                        <MudStack Row Wrap="Wrap.Wrap" Spacing="1">
                            @foreach (var skill in Skills)
                            {
                                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small" Class="core-chip">@skill</MudChip>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudTimelineItem>
}

<style>
    .timeline-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease !important;
        overflow: hidden;
    }

        .timeline-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.15), 0 0 0 2px rgba(var(--mud-palette-info-rgb), 0.3) !important;
        }

    .timeline-accent {
        height: 4px;
        background: linear-gradient(90deg, var(--mud-palette-info), var(--mud-palette-primary));
    }

    .timeline-card-mini {
        transition: box-shadow 0.2s ease !important;
        overflow: hidden;
    }

        .timeline-card-mini:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.10) !important;
        }
</style>

@code {
    public record Project(string Title, List<string>? Tasks);

    [Parameter] public required string CompanyLogo { get; set; }
    [Parameter] public required string JobTitle { get; set; }
    [Parameter] public required string Company { get; set; }
    [Parameter] public required DateTime StartDate { get; set; }
    [Parameter] public required DateTime EndDate { get; set; }
    [Parameter] public required string Place { get; set; }
    [Parameter] public required List<Project> Projects { get; set; }
    [Parameter] public required List<string>? Skills { get; set; }
    [Parameter] public bool IsInternship { get; set; } = false;

    private string _duration = "";
    private bool _expanded = false;

    protected override void OnParametersSet()
    {
        _duration = ComputeDurationString(StartDate, EndDate);
    }

    private void OnExpandCollapseClick() => _expanded = !_expanded;

    private string ComputeDurationString(DateTime start, DateTime end)
    {
        if (end < start) (start, end) = (end, start);
        var totalMonths = (end.Year - start.Year) * 12 + (end.Month - start.Month) + 1;
        if (end.Day < start.Day) totalMonths--;
        if (totalMonths <= 0) return "";
        var years = totalMonths / 12;
        var months = totalMonths % 12;
        string YearPart() => years > 0 ? $"{years} {(years > 1 ? SharedLocalizer["Years"] : SharedLocalizer["Year"])}" : "";
        string MonthPart() => months > 0 ? $"{months} {(months > 1 ? SharedLocalizer["Months"] : SharedLocalizer["Month"])}" : "";
        return years > 0 ? (months > 0 ? $"{YearPart()} {MonthPart()}" : YearPart()) : MonthPart();
    }
}
