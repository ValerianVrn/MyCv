@using MyCv.UI.Services
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Home> Localizer
@inject IStringLocalizer<MyCv.UI.Resources.Components.Pages.Career> CareerLocalizer;
@inject IStringLocalizer<MyCv.UI.Resources.Shared> SharedLocalizer;
@inject IThemeService ThemeService
@inject IConfiguration Configuration


<MudContainer Class="py-8" id="career">
    <MudContainer Class="@Style.LargeBottomMargin">
        <MudText Typo="Typo.h4" Align="Align.Center">@SharedLocalizer["Career"]</MudText>
        @if (Configuration.GetValue<bool>("SinglePage"))
        {
            <MudText Typo="Typo.body1" Align="Align.Center">@CareerLocalizer["Introduction"]</MudText>
        }
    </MudContainer>
    <MudContainer Class="@Style.LargeBottomMargin">
        <MudHidden Breakpoint="Breakpoint.LgAndUp">
            <MudExpansionPanels>
                @foreach (var experience in _experiences)
                {
                    <ExperienceExpansionItem CompanyLogo="@experience.CompanyLogo"
                                             JobTitle="@experience.JobTitle"
                                             Company="@experience.Company"
                                             StartDate="@experience.StartDate"
                                             EndDate="@experience.EndDate"
                                             Place="@experience.Place"
                                             Projects="@experience.Projects"
                                             Skills="@experience.Skills"
                                             IsInternship="@experience.IsInternship" />
                }
            </MudExpansionPanels>
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.LgAndUp" Invert>
            <MudTimeline TimelinePosition="TimelinePosition.Start" Modifiers>
                @foreach (var experience in _experiences)
                {
                    <ExperienceTimelineItem CompanyLogo="@experience.CompanyLogo"
                                            JobTitle="@experience.JobTitle"
                                            Company="@experience.Company"
                                            StartDate="@experience.StartDate"
                                            EndDate="@experience.EndDate"
                                            Place="@experience.Place"
                                            Projects="@experience.Projects"
                                            Skills="@experience.Skills"
                                            IsInternship="@experience.IsInternship" />
                }
            </MudTimeline>
        </MudHidden>
    </MudContainer>
</MudContainer>


@code {

