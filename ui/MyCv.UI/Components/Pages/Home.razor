@page "/"
@using MyCv.UI.Components.Layout
@using MyCv.UI.Components.Shared
@using MyCv.UI.Services
@using System.Timers;
@inject IStringLocalizer<Resource> Localizer
@layout MainLayout

<PageTitle>@Localizer["HomeHeader"]</PageTitle>

<MudGrid Spacing="20" Justify="Justify.Center">
    <MudItem md="12">
        <MudText Typo="Typo.h2" Align="Align.Left">@Localizer["HomeHeader"]</MudText>
    </MudItem>
    <MudItem md="6">
        <Terminal />
    </MudItem>
    <MudItem md="3">
        <MudImage Fluid="true" Src="images/portrait.jpg" Alt="Portrait" Class="rounded-lg" />
    </MudItem>
    <MudItem>
        <MudPaper Class="pa-16 ma-2" Square="true" Elevation="0">
            <MudText Typo="Typo.h4" Align="Align.Center">Skills & Expertise</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-6">Comprehensive technical skills and leadership experience in modern software development</MudText>
            <MudGrid>
                @foreach (var mainSkill in MainSkills)
                {
                    <MudItem xs="12" md="6">
                        <MudCard Elevation="2" Style="height: 100%">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudStack Row="true" Spacing="6" AlignItems="AlignItems.Center">
                                        <MudPaper Class="@mainSkill.Icon.BackgroundClass" Elevation="0">
                                            <MudIcon Icon="@mainSkill.Icon.Name" Style="@mainSkill.Icon.Style" />
                                        </MudPaper>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.h6">@mainSkill.Name</MudText>
                                            <MudText Typo="Typo.subtitle1">@mainSkill.Description</MudText>
                                        </MudStack>
                                    </MudStack>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Default" Href="@mainSkill.Href" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @foreach (var skill in mainSkill.Skills)
                                {
                                    if (skill.Core)
                                    {

                                        <MudChip T="string" Icon="@Icons.Material.Filled.Star" IconColor="Color.Warning" Color="Color.Dark">@skill.Name</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Color="Color.Surface">@skill.Name</MudChip>

                                    }
                                }
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@mainSkill.Href">Explore</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    </MudItem>
    <MudItem md="9">
        <MudGrid Spacing="6">
            <MudItem md="12">
                <MudText Typo="Typo.h6" Class="mud-text-secondary" GutterBottom="true">@Localizer["HomeIntroduction"]</MudText>
            </MudItem>
            <MudItem md="12">
                <MudText Typo="Typo.body1" Align="Align.Justify" GutterBottom="true" Inline=@true>@Localizer["HomeSourceCode"]</MudText> <MudLink Href="https://github.com/ValerianVrn/MyCv.git">GitHub</MudLink>.
            </MudItem>
            <MudItem md="12">
                <MudButton Variant="Variant.Text" Color="Color.Primary">@Localizer["HomeStart"] <MudIcon Icon="@Icons.Material.Filled.ArrowRightAlt" Title="Favorite" /></MudButton>
            </MudItem>
        </MudGrid>
    </MudItem>
</MudGrid>


@code {
    public record MainSkill(Icon Icon, string Name, string Description, string Href, List<Skill> Skills);
    public record Skill(string Name, bool Core);
    public class Icon(string name, string color)
    {
        public string Name { get { return name; } }
        public string Style { get { return "color: " + color; } }
        public string BackgroundClass { get { return color + " pa-4 lighten-5"; } }
    }

    public List<MainSkill> MainSkills
    {
        get
        {
            return new()
            {
                new(new(Icons.Material.Outlined.Code, "blue"), Localizer["DevelopmentAndTesting"], Localizer["CoreTechnologyExpertise"], Urls.Skills, new()
                {
                    new("ASP .NET core", true),
                    new("Entity Framework", false),
                    new("Blazor (WASM/Server)", false),
                    new("SQL Server", false),
                    new("OData", false),
                    new("SignalR", false),
                    new("MSTest", true),
                    new("React", false),
                }),
                new(new(Icons.Material.Outlined.Cloud, "green"), Localizer["Architecture"], Localizer["ScalableSystemDesign"], Urls.Architecture, new()
                {
                    new("Azure", false),
                    new("Microservices", true),
                    new("CQRS", true),
                    new("Event sourcing", true),
                    new("RabbitMQ", false),
                    new("API Gateway", false)
                }),
                new(new(Icons.Material.Outlined.People, "red"), Localizer["Leadership"], Localizer["TeamManagement"], Urls.Leadership, new()
                {
                    new("Agile/Scrum", false),
                    new("Code reviews", true),
                    new("Mentoring", true)
                }),
                new(new(Icons.Material.Outlined.Commit, "purple"), Localizer["DevOps"], Localizer["CICDAndMonitoring"], Urls.DevOps, new()
                {
                    new("Git flow", true),
                    new("Azure DevOps", true),
                    new("Docker", false),
                    new("Grafana", true),
                    new("Loki", true),
                    new("Prometheus", true),
                    new("OpenID", true)
                })
            };
        }
    }
}
